## Twine: "De Volda Ao Laboratório" (pid 1)
label de_volta_ao_laboratorio:
    scene bg sala_professor
    show professor idle at professor_sala_pose
    with dissolve
    $ jussara_checkpoint("finais_lab")
    p "Olá! Bem vindo de volta! Como foi a experiência em Belém?"

    menu:
        "Foi incrível!":
            call foi_incrivel from _call_foi_incrivel
        "Terrrível":
            call terrrivel from _call_terrrivel
        "Nada de novo":
            call nada_de_novo from _call_nada_de_novo

    return

